vẫn trả JSON có cấu trúc.\"\"\"\n356:     if audience == \"teacher\":\n357:         return _offline_fallback_teacher(steps, student_name)\n358:     else:\n359:         return _offline_fallback_\n<truncated 3256 bytes>\n:         \"center\": \"Học ở trung tâm\",\n423:         \"self_study\": \"Tự học qua mạng\"\n424:     }\n425:     env_text = env_map.get(learning_environment, learning_environment)\n426:     \n427:     user_msg = (\n428:         f\"Học sinh: {student_name}\\n\"\n429:         f\"Khối lớp: {grade}\\n\"\n430:         f\"Số năm học Tiếng Anh: {years_studying_english} năm\\n\"\n431:         f\"Môi trường học tập: {env_text}\\n\"\n432:         f\"Tự đánh giá trình độ hiện tại: {self_assessment_level}\\n\"\n433:         f\"Mục tiêu học tập: {learning_goal}\\n\\n\"\n434:         \"Hãy lập lộ trình học tập và kế hoạch đào tạo cá nhân hóa cho học sinh này.\"\n435:     )\n436:     \n437:     if settings.llm_mode == \"offline\":\n438:         return (\n439:             f\"[Lộ trình tạm thời — chế độ offline]\\n\"\n440:             f\"Dựa trên khảo sát của em {student_name} ({grade}), với mục tiêu '{learning_goal}', \"\n441:             \"hệ thống khuyến nghị tập trung ôn tập ngữ pháp và từ vựng theo chương trình học trên lớp.\"\n442:         )\n443: \n444:     try:\n445:         resp = call_llm(\n446:             system=SURVEY_SYSTEM_PROMPT,\n447:             messages=[{\"role\": \"user\", \"content\": user_msg}],\n448:             tools=None,\n449:         )\n450:         return resp.get(\"text\") or \"(Hệ thống chưa sinh được lộ trình. Vui lòng thử lại.)\"\n451:     except Exception as e:\n452:         return (\n453:             f\"[Lộ trình tạm thời — LLM chưa khả dụng: {e}]\\n\"\n454:             f\"Dựa trên khảo sát của em {student_name} ({grade}), với mục tiêu '{learning_goal}', \"\n455:             \"hệ thống khuyến nghị tập trung ôn tập ngữ pháp và từ vựng theo chương trình học trên lớp.\"\n456:         )\n457: \n458: \nThe above content does NOT show th