ze={size} className={className} style={style} />;\n44: }\n45: \n46: const LEVELS = [\n47:   { id: 'starter', label: 'Mới bắt đầu', cefr: 'Pre-A1', icon: 'sentiment_satisfied', desc: 'Em mới làm quen với Ti\n<truncated 4299 bytes>\n54:           let testQuestionIds = [];\n155:           if (testQRes.ok) {\n156:             const tests = await testQRes.json();\n157:             const test = tests.find(t => t.test_id === 'placement-test-en-2026');\n158:             if (test) {\n159:               const tqRes = await apiFetch(`/api/placement-tests/${test.id}/questions`);\n160:               if (tqRes.ok) {\n161:                 const tqData = await tqRes.json();\n162:                 testQuestionIds = tqData.map(q => q.question_id);\n163:               }\n164:             }\n165:           }\n166:           const filtered = testQuestionIds.length > 0\n167:             ? all.filter(q => testQuestionIds.includes(q.question_id))\n168:             : all.slice(0, 14);\n169:           setQuestions(filtered);\n170:         }\n171:       } catch (e) {\n172:         console.error('Error loading questions:', e);\n173:       } finally {\n174:         setLoading(false);\n175:       }\n176:     };\n177:     load();\n178:   }, []);\n179: \n180:   return { questions, loading };\n181: }\n182: \n183: function StepIndicator({ currentStep }) {\n184:   const steps = ['Chọn cấp độ', 'Làm bài', 'Kết quả'];\n185:   return (\n186:     <div className=\"survey-stepper\">\n187:       {steps.map((label, i) => (\n188:         <React.Fragment key={i}>\n189:           {i > 0 && <div className={`survey-stepper-line ${i <= currentStep ? 'active' : ''}`} />}\n190:           <div className=\"survey-stepper-step\">\n191:             <div className={`survey-stepper-circle ${i <= currentStep ? 'active' : ''}`}>\n192:               {i < currentStep ? <Icon name=\"check_circle\" size={16} /> : i + 1}\n193:             </div>\n194:             <span className={`survey-stepper-label ${i <= currentStep ? 'active' : ''}`}>{label}</span>\n195:           </div>\n196:         </React.Fragment>\n197:       ))}\n198:     </div>\n199:   );\n200: }\nThe above content does NOT show the entire file contents. If you need to view any lines of the file which were not shown to complete your task, call this tool again to view those lines.\n","truncated_fields":["content"]}
