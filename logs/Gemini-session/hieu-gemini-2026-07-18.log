{"step_index":38,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T06:43:46Z","content":"Created At: 2026-07-18T13:43:46+07:00\nCompleted At: 2026-07-18T13:43:46+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/agent/llm_client.py`\nTotal Lines: 159\nTotal Bytes: 5605\nShowing lines 1 to 159\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"LLM client: hỗ trợ FPT AI Inference, Ollama (local), và offline template fallback.\n2: \n3: Chế độ hoạt động được cấu hình qua env LLMMODE:\n4:   - fpt (mặc định): Gọi FPT AI Inference (OpenAI-compatible)\n5:   - ollama: Gọi Ollama local (OpenAI-compatible endpoint tại http://ollama:11434/v1)\n6:   - offline: Không gọi LLM nào, trả về template fallback từ caller\n7: \"\"\"\n8: import os\n9: \n10: from app.config import settings\n11: \n12: \n13: # ---------------------------------------------------------------------------\n14: # 1. FPT AI Inference (cloud) — giữ nguyên API cũ\n15: # ---------------------------------------------------------------------------\n16: \n17: def create_message(*, model: str, system: str, messages: list[dict], tools: list[dict]):\n18:     \"\"\"Anthropic API (dùng bởi PlannerAgent /chat cũ).\"\"\"\n19:     from anthropic import Anthropic\n20: \n21:     _client = Anthropic(api_key=os.environ.get(\"ANTHROPIC_API_KEY\", \"\"))\n22:     return _client.messages.create(\n23:         model=model,\n24:         system=system,\n25:         messages=messages,\n26:         tools=tools,\n27:         max_tokens=1024,\n28:     )\n29: \n30: \n31: def create_message_fpt(*, system: str, messages: list[dict], tools: list[dict] = None, model: str = None):\n32:     \"\"\"Gọi FPT AI Inference (OpenAI-compatible chat completions).\n33: \n34:     Trả về dict: {\"text\": str, \"tool_calls\": [{\"name\", \"input\"}]} để Planner Agent\n35:     (hoặc tool trực tiếp) dễ sử dụng. Nếu không có tool_call thì chỉ có text.\n36:     \"\"\"\n37\n<truncated 2743 bytes>\n]\n111: \n112:     completion = client.chat.completions.create(\n113:         model=req_model,\n114:         messages=[{\"role\": \"system\", \"content\": system}, *messages],\n115:         tools=openai_tools,\n116:         tool_choice=\"auto\" if openai_tools else None,\n117:         temperature=0.1,  # thấp hơn cho model local — ưu tiên ổn định\n118:     )\n119:     choice = completion.choices[0].message\n120: \n121:     text = choice.content or \"\"\n122:     tool_calls = []\n123:     if getattr(choice, \"tool_calls\", None):\n124:         for tc in choice.tool_calls:\n125:             import json\n126: \n127:             try:\n128:                 args = json.loads(tc.function.arguments or \"{}\")\n129:             except Exception:\n130:                 args = {}\n131:             tool_calls.append({\"name\": tc.function.name, \"input\": args})\n132: \n133:     return {\"text\": text, \"tool_calls\": tool_calls}\n134: \n135: \n136: # ---------------------------------------------------------------------------\n137: # 3. Dispatcher — chọn client theo LLM_MODE\n138: # ---------------------------------------------------------------------------\n139: \n140: def call_llm(*, system: str, messages: list[dict], tools: list[dict] = None, model: str = None):\n141:     \"\"\"Dispatcher tự động chọn FPT / Ollama / offline theo settings.llm_mode.\n142: \n143:     Trả về dict: {\"text\": str, \"tool_calls\": list, \"mode\": str}\n144:     \"\"\"\n145:     mode = settings.llm_mode\n146: \n147:     if mode == \"ollama\":\n148:         result = create_message_ollama(system=system, messages=messages, tools=tools, model=model)\n149:         result[\"mode\"] = \"ollama\"\n150:         return result\n151: \n152:     if mode == \"offline\":\n153:         return {\"text\": \"\", \"tool_calls\": [], \"mode\": \"offline\"}\n154: \n155:     # Mặc định: FPT cloud\n156:     result = create_message_fpt(system=system, messages=messages, tools=tools, model=model)\n157:     result[\"mode\"] = \"fpt\"\n158:     return result\n159: \nThe above content shows the entire, complete file contents of the requested file.\n","truncated_fields":["content"]}
