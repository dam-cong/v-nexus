{"step_index":34,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T06:43:42Z","content":"Created At: 2026-07-18T13:43:42+07:00\nCompleted At: 2026-07-18T13:43:42+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/gateway/app/config.py`\nTotal Lines: 35\nTotal Bytes: 1364\nShowing lines 1 to 35\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"Cấu hình non-secret của Gateway. Secret (API key, mật khẩu DB) nằm ở .env.\"\"\"\n2: import os\n3: \n4: from dotenv import load_dotenv\n5: \n6: load_dotenv()\n7: \n8: \n9: class Settings:\n10:     # --- LLM mode: \"fpt\" (cloud) | \"ollama\" (local) | \"offline\" (template fallback) ---\n11:     llm_mode: str = os.environ.get(\"LLM_MODE\", \"fpt\")\n12: \n13:     # --- FPT AI Inference (OpenAI-compatible) ---\n14:     fpt_api_key: str = os.environ.get(\"API_KEY\", os.environ.get(\"FPT_API_KEY\", \"\"))\n15:     fpt_api_base: str = os.environ.get(\"LLM_BASE_URL\", os.environ.get(\"FPT_API_BASE\", \"https://mkp-api.fptcloud.com/v1\"))\n16:     fpt_model: str = os.environ.get(\"LLM_MODEL\", os.environ.get(\"FPT_MODEL\", \"GLM-5.2\"))\n17: \n18:     # --- Anthropic (legacy /chat) ---\n19:     anthropic_api_key: str = os.environ.get(\"ANTHROPIC_API_KEY\", \"\")\n20:     llm_model: str = os.environ.get(\"LLM_MODEL\", \"claude-sonnet-5\")\n21: \n22:     # --- Ollama (local) ---\n23:     ollama_base_url: str = os.environ.get(\"OLLAMA_BASE_URL\", \"http://ollama:11434/v1\")\n24:     ollama_model: str = os.environ.get(\"OLLAMA_MODEL\", \"qwen3:1.7b\")\n25: \n26:     # --- DB ---\n27:     database_url: str = os.environ.get(\n28:         \"DATABASE_URL\", \"postgresql+asyncpg://vnexus:vnexus@localhost:5432/vnexus\"\n29:     )\n30:     mcp_server_url: str = os.environ.get(\"MCP_SERVER_URL\", \"http://mcp_server:8100/mcp\")\n31:     auth_secret: str = os.environ.get(\"AUTH_SECRET\", \"change-me-dev-only-secret\")\n32: \n33: \n34: settings = Settings()\n35: \nThe above content shows the entire, complete file contents of the requested file.\n"}
