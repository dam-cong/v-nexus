{"step_index":30,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T14:57:13Z","content":"Created At: 2026-07-18T21:57:13+07:00\nCompleted At: 2026-07-18T21:57:13+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/tools/plan_tool.py`\nTotal Lines: 446\nTotal Bytes: 19576\nShowing lines 1 to 446\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"Tool 2: Sinh kế hoạch đào tạo cá nhân hóa (Tầng 3 — LLM Output Layer).\n2: \n3: Áp dụng các kỹ thuật tối ưu prompt theo prompt.md:\n4: - Ràng buộc grounding rõ ràng (LLM chỉ diễn giải, không quyết định lộ trình)\n5: - Input có cấu trúc (bảng từ BKT Engine, không văn xuôi tự do)\n6: - Few-shot (1 ví dụ mẫu trong prompt)\n7: - Chain-of-thought có kiểm soát (liệt kê lý do trước khi viết lời)\n8: - Structured output (JSON có schema)\n9: - Temperature thấp (0.2)\n10: - Tách prompt theo đối tượng (học sinh vs giáo viên/phụ huynh)\n11: - Post-validation (cross-check skill_id)\n12: - Offline fallback template\n13: \"\"\"\n14: import json\n15: import re\n16: \n17: from agent.llm_client import call_llm\n18: from domain.bkt import generate_learning_steps, format_steps_for_llm, get_input_skill_ids\n19: from tools.base import Tool\n20: \n21: \n22: # ---------------------------------------------------------------------------\n23: # 1. SYSTEM PROMPTS — tách riêng theo đối tượng\n24: # ---------------------------------------------------------------------------\n25: \n26: _STUDENT_SYSTEM_PROMPT = \"\"\"Bạn là Medi Bee, trợ lý AI gia sư của V-Nexus Tutor.\n27: \n28: NGUYÊN TẮC BẮT BUỘC (grounding):\n29: - Bạn CHỈ diễn giải dữ liệu lộ trình được cung cấp trong input.\n30: - TUYỆT ĐỐI không thêm bước mới, không đổi thứ tự, không tự bịa kỹ năng ngoài danh sách.\n31: - Nếu dữ liệu input rỗng, hãy chúc mừng học sinh và đề x\n<truncated 18151 bytes>\n rõ ràng, phân chia các phần mạch lạc.\"\n403: )\n404: \n405: \n406: def generate_training_plan_from_survey(\n407:     student_name: str,\n408:     grade: str,\n409:     years_studying_english: int,\n410:     learning_environment: str,\n411:     self_assessment_level: str,\n412:     learning_goal: str\n413: ) -> str:\n414:     \"\"\"Gọi FPT LLM để sinh kế hoạch đào tạo dựa trên khảo sát đầu vào.\"\"\"\n415:     env_map = {\n416:         \"school\": \"Chỉ học ở trường\",\n417:         \"center\": \"Học ở trung tâm\",\n418:         \"self_study\": \"Tự học qua mạng\"\n419:     }\n420:     env_text = env_map.get(learning_environment, learning_environment)\n421:     \n422:     user_msg = (\n423:         f\"Học sinh: {student_name}\\n\"\n424:         f\"Khối lớp: {grade}\\n\"\n425:         f\"Số năm học Tiếng Anh: {years_studying_english} năm\\n\"\n426:         f\"Môi trường học tập: {env_text}\\n\"\n427:         f\"Tự đánh giá trình độ hiện tại: {self_assessment_level}\\n\"\n428:         f\"Mục tiêu học tập: {learning_goal}\\n\\n\"\n429:         \"Hãy lập lộ trình học tập và kế hoạch đào tạo cá nhân hóa cho học sinh này.\"\n430:     )\n431:     \n432:     try:\n433:             resp = call_llm(\n434:                 system=SURVEY_SYSTEM_PROMPT,\n435:                 messages=[{\"role\": \"user\", \"content\": user_msg}],\n436:                 tools=None,\n437:             )\n438:             return resp.get(\"text\") or \"(Hệ thống chưa sinh được lộ trình. Vui lòng thử lại.)\"\n439:     except Exception as e:\n440:         return (\n441:             f\"[Lộ trình tạm thời - LLM chưa khả dụng: {e}]\\n\"\n442:             f\"Dựa trên khảo sát của em {student_name} ({grade}), với mục tiêu '{learning_goal}', \"\n443:             \"hệ thống khuyến nghị tập trung ôn tập ngữ pháp và từ vựng theo chương trình học trên lớp.\"\n444:         )\n445: \n446: \nThe above content shows the entire, complete file contents of the requested file.\n","truncated_fields":["content"]}
