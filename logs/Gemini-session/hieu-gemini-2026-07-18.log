{"step_index":32,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T06:43:40Z","content":"Created At: 2026-07-18T13:43:40+07:00\nCompleted At: 2026-07-18T13:43:40+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/gateway/app/routes/chat.py`\nTotal Lines: 35\nTotal Bytes: 931\nShowing lines 1 to 35\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"Endpoint /chat — cầu nối duy nhất giữa frontend và Planner Agent.\"\"\"\n2: from fastapi import APIRouter\n3: from pydantic import BaseModel\n4: \n5: from agent.planner import PlannerAgent\n6: from domain.sme_innovation_adapter import VNexusTutorAdapter\n7: \n8: from ..config import settings\n9: \n10: router = APIRouter()\n11: _adapter = VNexusTutorAdapter()\n12: _agent = PlannerAgent(domain=_adapter, model=settings.llm_model)\n13: \n14: \n15: class ChatRequest(BaseModel):\n16:     message: str\n17:     history: list[dict] = []\n18: \n19: \n20: class ChatResponse(BaseModel):\n21:     reply: str\n22:     history: list[dict]\n23: \n24: \n25: @router.post(\"/chat\", response_model=ChatResponse)\n26: async def chat(req: ChatRequest) -> ChatResponse:\n27:     reply, history = await _agent.run(req.message, req.history)\n28:     return ChatResponse(reply=reply, history=history)\n29: \n30: \n31: @router.get(\"/health/llm\")\n32: async def llm_health():\n33:     \"\"\"Kiểm tra trạng thái LLM: online (fpt/ollama) hay offline.\"\"\"\n34:     return {\"mode\": settings.llm_mode}\n35: \nThe above content shows the entire, complete file contents of the requested file.\n"}
