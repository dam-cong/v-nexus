ext: .\n49:       dockerfile: gateway/Dockerfile\n50:     env_file: .env\n51:     environment:\n52:       DATABASE_URL: ${DATABASE_URL:-postgresql+asyncpg://vnexus:vnexus@db:5432/vnexus}\n53:       MCP_SERVER_URL: ${MCP_SERVER_URL:-http://mcp_server:8100/mcp}\n54:       OLLAMA_BASE_URL: ${OLLAMA_BASE_URL:-http://ollama:11434/v1}\n55:       OLLAMA_MODEL: ${OLLAMA_MODEL:-qwen3:1.7b}\n56:     depends_on:\n57:       db:\n58:         condition: service_healthy\n59:       mcp_server:\n60:         condition: service_started\n61:       ollama:\n62:         condition: service_healthy\n63:     ports:\n64:       - \"8000:8000\"\n65: \n66:   frontend:\n67:     build:\n68:       context: ./frontend\n69:       dockerfile: Dockerfile\n70:     environment:\n71:       GATEWAY_URL: http://gateway:8000\n72:     depends_on:\n73:       - gateway\n74:     ports:\n75:       - \"8081:8501\"\n76: \n77: volumes:\n78:   vnexus_db_data:\n79:   ollama_data:\n80: \nThe above content shows the entire, complete file contents of the requested file.\n"}
