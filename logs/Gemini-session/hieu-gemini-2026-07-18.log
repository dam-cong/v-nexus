ostgresql+asyncpg://vnexus:vnexus@db:5432/vnexus}\n52:       MCP_SERVER_URL: ${MCP_SERVER_URL:-http://mcp_server:8100/mcp}\n53:       OLLAMA_BASE_URL: ${OLLAMA_BASE_URL:-http://ollama:11434/v1}\n54:     depends_on:\n55:       db:\n56:         condition: service_healthy\n57:       mcp_server:\n58:         condition: service_started\n59:       ollama:\n60:         condition: service_healthy\n61:     ports:\n62:       - \"8000:8000\"\n63: \n64:   frontend:\n65:     build:\n66:       context: ./frontend\n67:       dockerfile: Dockerfile\n68:     environment:\n69:       GATEWAY_URL: http://gateway:8000\n70:     depends_on:\n71:       - gateway\n72:     ports:\n73:       - \"8081:8501\"\n74: \n75: volumes:\n76:   vnexus_db_data:\n77:   ollama_data:\n78: \nThe above content shows the entire, complete file contents of the requested file.\n"}
