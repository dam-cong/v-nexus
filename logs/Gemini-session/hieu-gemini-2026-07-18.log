àn thành lộ trình.\"\"\"\n1034:     result = await db.execute(select(StudentTestResult).where(StudentTestResult.id == result_id))\n1035:     test_result = result.scalar_one_or_none(\n<truncated 15 bytes>\nnot test_result:\n1037:         raise HTTPException(status_code=404, detail=\"Test result not found\")\n1038: \n1039:     if user.get(\"role\") == \"hoc_sinh\" and test_result.user_id != user[\"id\"]:\n1040:         raise HTTPException(status_code=403, detail=\"Không có quyền\")\n1041: \n1042:     orig_gaps = test_result.gaps or []\n1043:     assessment = run_assessment(body.answers or [], None)\n1044:     new_mastery = assessment[\"mastery\"]\n1045: \n1046:     remaining_gaps = []\n1047:     for g in orig_gaps:\n1048:         prob = (new_mastery.get(g.get(\"skill_id\"), {}) or {}).get(\"probability\") or 0\n1049:         if prob < 0.7:\n1050:             remaining_gaps.append({\n1051:                 \"skill_id\": g.get(\"skill_id\"),\n1052:                 \"skill_name\": g.get(\"skill_name\"),\n1053:                 \"probability\": round(prob * 100) / 100,\n1054:             })\n1055: \n1056:     passed = len(orig_gaps) > 0 and len(remaining_gaps) == 0\n1057:     if passed:\n1058:         test_result.quick_check_passed = True\n1059:         test_result.roadmap_completed = True\n1060:         await db.commit()\n1061:         await db.refresh(test_result)\n1062: \n1063:     return {\n1064:         \"passed\": passed,\n1065:         \"roadmap_completed\": test_result.roadmap_completed,\n1066:         \"remaining_gaps\": remaining_gaps,\n1067:         \"mastery\": new_mastery,\n1068:     }\n1069: \n1070: \n1071: @router.post(\"/placement-tests/{test_id}/submit\", response_model=TestResultResponse, status_code=status.HTTP_201_CREATED)\n1072: async def submit_placement_test(\n1073:     test_id: int,\n1074:     body: TestResultSubmit,\n1075:     db: AsyncSession = Depends(get_session),\n1076:     user: dict = Depends(get_current_user),\n1077: ):\n1078:     result = aw