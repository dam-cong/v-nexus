{"step_index":88,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T14:58:18Z","content":"Created At: 2026-07-18T21:58:18+07:00\nCompleted At: 2026-07-18T21:58:18+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/agent/llm_client.py`\nTotal Lines: 161\nTotal Bytes: 5420\nShowing lines 1 to 161\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"LLM client: hỗ trợ cả Anthropic (cũ) và FPT AI Inference (OpenAI-compatible).\n2: \n3: FPT endpoint là OpenAI-compatible: https://mkp-api.fptcloud.com/v1\n4: Model mặc định: DeepSeek-V4-Flash (cấu hình qua env FPT_MODEL).\n5: \"\"\"\n6: import os\n7: \n8: from app.config import settings\n9: \n10: \n11: def create_message(*, model: str, system: str, messages: list[dict], tools: list[dict]):\n12:     \"\"\"Giữ nguyên API cho Anthropic (dùng bởi /chat cũ).\"\"\"\n13:     from anthropic import Anthropic\n14: \n15:     _client = Anthropic(api_key=os.environ.get(\"ANTHROPIC_API_KEY\", \"\"))\n16:     return _client.messages.create(\n17:         model=model,\n18:         system=system,\n19:         messages=messages,\n20:         tools=tools,\n21:         max_tokens=1024,\n22:     )\n23: \n24: \n25: def create_message_fpt(*, system: str, messages: list[dict], tools: list[dict] = None, model: str = None):\n26:     \"\"\"Gọi FPT AI Inference (OpenAI-compatible chat completions).\n27: \n28:     Trả về dict: {\"text\": str, \"tool_calls\": [{\"name\", \"input\"}]} để Planner Agent\n29:     (hoặc tool trực tiếp) dễ sử dụng. Nếu không có tool_call thì chỉ có text.\n30:     \"\"\"\n31:     from openai import OpenAI\n32: \n33:     client = OpenAI(base_url=settings.llm_base_url, api_key=settings.api_key, timeout=30.0)\n34:     req_model = model or settings.llm_model\n35: \n36:     openai_tools = None\n37:     if tools:\n38:         openai_tools = [\n39:             {\n40:                 \"type\": \"function\",\n41:                 \"function\": {\n42:                     \"name\": t[\"name\"\n<truncated 2568 bytes>\nction.arguments or \"{}\")\n115:             except Exception:\n116:                 args = {}\n117:             tool_calls.append({\"name\": tc.function.name, \"input\": args})\n118: \n119:     return {\"text\": text, \"tool_calls\": tool_calls}\n120: \n121: \n122: def call_llm(*, system: str, messages: list[dict], tools: list[dict] = None, model: str = None):\n123:     \"\"\"Bộ điều phối (dispatcher) cuộc gọi LLM dựa trên LLM_MODE.\"\"\"\n124:     mode = (settings.llm_mode or \"offline\").lower()\n125:     if mode == \"fpt\":\n126:         return create_message_fpt(system=system, messages=messages, tools=tools, model=model)\n127:     elif mode == \"ollama\":\n128:         return create_message_ollama(system=system, messages=messages, tools=tools, model=model)\n129:     elif mode == \"offline\":\n130:         raise RuntimeError(\"LLM is configured in offline mode.\")\n131:     else:\n132:         raise ValueError(f\"Unknown LLM mode: {settings.llm_mode}\")\n133: \n134: \n135: def is_llm_available() -> bool:\n136:     \"\"\"Kiểm tra xem LLM hiện tại có thể kết nối được không.\"\"\"\n137:     mode = (settings.llm_mode or \"offline\").lower()\n138:     if mode == \"offline\":\n139:         return False\n140: \n141:     import requests\n142: \n143:     if mode == \"fpt\":\n144:         if not settings.api_key:\n145:             return False\n146:         try:\n147:             url = f\"{settings.llm_base_url.rstrip('/')}/models\"\n148:             headers = {\"Authorization\": f\"Bearer {settings.api_key}\"}\n149:             r = requests.get(url, headers=headers, timeout=3.0)\n150:             return r.status_code == 200\n151:         except Exception:\n152:             return False\n153:     elif mode == \"ollama\":\n154:         try:\n155:             url = f\"{settings.ollama_base_url.rstrip('/')}/models\"\n156:             r = requests.get(url, timeout=3.0)\n157:             return r.status_code == 200\n158:         except Exception:\n159:             return False\n160:     return False\n161: \nThe above content shows the entire, complete file contents of the requested file.\n","truncated_fields":["content"]}
