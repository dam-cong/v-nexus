{"step_index":58,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T14:57:47Z","content":"Created At: 2026-07-18T21:57:47+07:00\nCompleted At: 2026-07-18T21:57:47+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/db/db.sql`\nTotal Lines: 57\nTotal Bytes: 1779\nShowing lines 1 to 57\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: -- V-Nexus Database Schema\n2: \n3: -- 1. Roles table\n4: CREATE TABLE IF NOT EXISTS roles (\n5:     id SERIAL PRIMARY KEY,\n6:     name VARCHAR(50) UNIQUE NOT NULL,\n7:     description VARCHAR(255)\n8: );\n9: \n10: -- Pre-populate default roles\n11: INSERT INTO roles (id, name, description)\n12: VALUES \n13:     (1, 'hoc_sinh', 'Học sinh tham gia học tập'),\n14:     (2, 'giao_vien', 'Giáo viên quản lý và giảng dạy'),\n15:     (3, 'admin', 'Quản trị viên hệ thống')\n16: ON CONFLICT (id) DO NOTHING;\n17: \n18: -- 2. Teachers table\n19: CREATE TABLE IF NOT EXISTS teachers (\n20:     id SERIAL PRIMARY KEY,\n21:     name VARCHAR(100) NOT NULL,\n22:     email VARCHAR(100) UNIQUE NOT NULL,\n23:     role_id INT REFERENCES roles(id) DEFAULT 2,\n24:     subject VARCHAR(100),\n25:     created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n26: );\n27: \n28: -- 3. Students table\n29: CREATE TABLE IF NOT EXISTS students (\n30:     id SERIAL PRIMARY KEY,\n31:     name VARCHAR(100) NOT NULL,\n32:     email VARCHAR(100) UNIQUE NOT NULL,\n33:     role_id INT REFERENCES roles(id) DEFAULT 1,\n34:     grade VARCHAR(50),\n35:     created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n36: );\n37: \n38: -- 4. Rankings table (Xếp hạng)\n39: CREATE TABLE IF NOT EXISTS rankings (\n40:     id SERIAL PRIMARY KEY,\n41:     student_id INT REFERENCES students(id) ON DELETE CASCADE,\n42:     score INT DEFAULT 0,\n43:     level VARCHAR(50) DEFAULT 'Beginner',\n44:     updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n45: );\n46: \n47: -- 5. Survey Evaluations table (Khảo sát đầu vào)\n48: CREATE TABLE IF NOT EXISTS survey_evaluations (\n49:     id SERIAL PRIMARY KEY,\n50:     student_id INT REFERENCES students(id) ON DELETE CASCADE,\n51:     years_studying_english INT DEFAULT 0,\n52:     learning_environment VARCHAR(100), -- 'school', 'center', 'self_study'\n53:     self_assessment_level VARCHAR(50), -- 'A1', 'A2', 'B1', 'B2', etc.\n54:     learning_goal TEXT,\n55:     created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n56: );\n57: \nThe above content shows the entire, complete file contents of the requested file.\n"}
