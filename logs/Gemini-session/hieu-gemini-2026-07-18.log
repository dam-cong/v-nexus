{"step_index":60,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T14:57:48Z","content":"Created At: 2026-07-18T21:57:48+07:00\nCompleted At: 2026-07-18T21:57:48+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/db/connector.py`\nTotal Lines: 242\nTotal Bytes: 9966\nShowing lines 1 to 242\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"PostgreSQL Connector dùng chung cho toàn bộ dự án.\"\"\"\n2: import os\n3: from collections.abc import AsyncIterator\n4: \n5: from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker, create_async_engine\n6: from sqlalchemy import select, text\n7: \n8: from db.models import Base, Role\n9: from db.seed import seed_data, seed_questions, seed_placement_tests, seed_test_results\n10: \n11: DATABASE_URL = os.environ.get(\n12:     \"DATABASE_URL\", \"postgresql+asyncpg://vnexus:vnexus@localhost:5432/vnexus\"\n13: )\n14: \n15: # Use pool_pre_ping to check connection and avoid stale connections\n16: engine = create_async_engine(DATABASE_URL, echo=False, pool_pre_ping=True)\n17: SessionLocal = async_sessionmaker(engine, expire_on_commit=False)\n18: \n19: \n20: async def get_session() -> AsyncIterator[AsyncSession]:\n21:     async with SessionLocal() as session:\n22:         yield session\n23: \n24: \n25: async def migrate_to_users() -> None:\n26:     \"\"\"Gộp students/teachers cũ vào bảng users trung tâm (chạy 1 lần, idempotent).\n27: \n28:     Bước:\n29:       1. Nếu bảng users đã có dữ liệu -> bỏ qua (đã migrate).\n30:       2. Nếu students/teachers cũ rỗng -> bỏ qua (chưa có data).\n31:       3. Với mỗi student/teacher cũ: tạo User, gán user_id vào profile.\n32:       4. Map old student.id/teacher.id -> user.id, cập nhật rankings/student_test_results.\n33:     \"\"\"\n34:     async with SessionLocal() as session:\n35:         # Check users already migrated\n36:         users_exist = await session.execute(text(\"SELECT 1 FROM users LIMIT 1\"))\n\n<truncated 7515 bytes>\n         await conn.execute(text(\"ALTER TABLE teachers DROP COLUMN IF EXISTS teacher_id;\"))\n205:         await conn.execute(text(\"ALTER TABLE teachers DROP COLUMN IF EXISTS name;\"))\n206:         await conn.execute(text(\"ALTER TABLE teachers DROP COLUMN IF EXISTS email;\"))\n207:         await conn.execute(text(\"ALTER TABLE teachers DROP COLUMN IF EXISTS hashed_password;\"))\n208:         await conn.execute(text(\"ALTER TABLE teachers DROP COLUMN IF EXISTS role_id;\"))\n209: \n210:     # 1c. Migrate dữ liệu cũ (students/teachers riêng) sang mô hình users + profile\n211:     await migrate_to_users()\n212: \n213:     # 2. Thêm các vai trò mặc định nếu chưa tồn tại\n214:     async with SessionLocal() as session:\n215:         async with session.begin():\n216:             result = await session.execute(select(Role).limit(1))\n217:             if not result.scalars().first():\n218:                 roles = [\n219:                     Role(id=1, name=\"hoc_sinh\", description=\"Học sinh tham gia học tập\"),\n220:                     Role(id=2, name=\"giao_vien\", description=\"Giáo viên quản lý và giảng dạy\"),\n221:                     Role(id=3, name=\"admin\", description=\"Quản trị viên hệ thống\"),\n222:                 ]\n223:                 session.add_all(roles)\n224: \n225:     # 3. Seed demo data\n226:     async with SessionLocal() as session:\n227:         async with session.begin():\n228:             await seed_data(session)\n229: \n230:     # 4. Seed questions, placement tests, and test results\n231:     async with SessionLocal() as session:\n232:         async with session.begin():\n233:             await seed_questions(session)\n234: \n235:     async with SessionLocal() as session:\n236:         async with session.begin():\n237:             await seed_placement_tests(session)\n238: \n239:     async with SessionLocal() as session:\n240:         async with session.begin():\n241:             await seed_test_results(session)\n242: \nThe above content shows the entire, complete file contents of the requested file.\n","truncated_fields":["content"]}
