{"step_index":86,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T14:58:15Z","content":"Created At: 2026-07-18T21:58:15+07:00\nCompleted At: 2026-07-18T21:58:15+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/setup.sh`\nTotal Lines: 79\nTotal Bytes: 2275\nShowing lines 1 to 79\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: #!/bin/bash\n2: set -e\n3: \n4: echo \"=========================================\"\n5: echo \"  V-Nexus Tutor - Server Setup Script\"\n6: echo \"=========================================\"\n7: \n8: PROJECT_DIR=\"/opt/sourecode/v-nexus\"\n9: \n10: # 1. Check if project exists, if not create directory\n11: if [ ! -d \"$PROJECT_DIR\" ]; then\n12:     echo \"[1/5] Creating project directory...\"\n13:     mkdir -p $PROJECT_DIR\n14: else\n15:     echo \"[1/5] Project directory exists.\"\n16: fi\n17: \n18: cd $PROJECT_DIR\n19: \n20: # 2. Create docs/data directory (required by Dockerfile)\n21: echo \"[2/5] Ensuring docs/data/ directory exists...\"\n22: mkdir -p docs/data\n23: \n24: # 3. Check if JSON files exist, if not warn user\n25: MISSING=0\n26: for f in question-bank.json placement-test.json survey-results.json knowledge-graph.json; do\n27:     if [ ! -f \"docs/data/$f\" ]; then\n28:         echo \"  WARNING: docs/data/$f not found!\"\n29:         MISSING=1\n30:     fi\n31: done\n32: \n33: if [ $MISSING -eq 1 ]; then\n34:     echo \"\"\n35:     echo \"  Please copy the following files to $PROJECT_DIR/docs/data/:\"\n36:     echo \"    - question-bank.json\"\n37:     echo \"    - placement-test.json\"\n38:     echo \"    - survey-results.json\"\n39:     echo \"    - knowledge-graph.json\"\n40:     echo \"\"\n41:     echo \"  You can use rsync from local:\"\n42:     echo \"    rsync -avz /home/hiendc/Documents/VAIC-2026/v-nexus/docs/data/ root@<server-ip>:$PROJECT_DIR/docs/data/\"\n43:     echo \"\"\n44:     read -p \"  Press Enter after copying files, or type 'skip' to continue without them: \" USER_INPUT\n45:     if [ \"$USER_INPUT\" != \"skip\" ]; then\n46:         echo \"  Resuming...\"\n47:     fi\n48: fi\n49: \n50: # 4. Stop old containers\n51: echo \"[3/5] Stopping old containers...\"\n52: docker-compose down 2>/dev/null || true\n53: \n54: # 5. Build and start\n55: echo \"[4/5] Building and starting containers...\"\n56: docker-compose build\n57: docker-compose up -d\n58: \n59: # 6. Show status\n60: echo \"[5/5] Container status:\"\n61: docker-compose ps\n62: \n63: echo \"\"\n64: echo \"=========================================\"\n65: echo \"  Setup complete!\"\n66: echo \"=========================================\"\n67: echo \"\"\n68: echo \"  Frontend:    http://localhost:8081\"\n69: echo \"  Gateway API: http://localhost:8000\"\n70: echo \"  MCP Server:  http://localhost:8500\"\n71: echo \"  Database:    localhost:5434\"\n72: echo \"\"\n73: echo \"  Login: admin@vnexus.vn / 123456\"\n74: echo \"\"\n75: echo \"  To rebuild:  docker-compose build && docker-compose up -d\"\n76: echo \"  To stop:     docker-compose down\"\n77: echo \"  To view logs: docker-compose logs -f\"\n78: echo \"\"\n79: \nThe above content shows the entire, complete file contents of the requested file.\n"}
