{"step_index":30,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T06:43:39Z","content":"Created At: 2026-07-18T13:43:39+07:00\nCompleted At: 2026-07-18T13:43:39+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/tests/test_bkt.py`\nTotal Lines: 77\nTotal Bytes: 2486\nShowing lines 1 to 77\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"Kiểm thử BKT Engine (docs/ai-danh-gia.md §2.5).\"\"\"\n2: import sys\n3: import os\n4: \n5: sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), \"..\")))\n6: \n7: from domain.bkt import (\n8:     ROOT_THRESHOLD,\n9:     PRIOR,\n10:     compute_mastery,\n11:     diagnose_gaps,\n12:     update_probability,\n13: )\n14: from domain.knowledge_graph import trace_root_causes\n15: \n16: \n17: def _mk_answers(skill_id, n_correct, n_wrong):\n18:     ans = []\n19:     for _ in range(n_correct):\n20:         ans.append({\"question_id\": f\"q_c_{skill_id}_{_}\", \"skill_id\": skill_id, \"correct\": True})\n21:     for _ in range(n_wrong):\n22:         ans.append({\"question_id\": f\"q_w_{skill_id}_{_}\", \"skill_id\": skill_id, \"correct\": False})\n23:     return ans\n24: \n25: \n26: def test_correct_increases():\n27:     p = PRIOR\n28:     for _ in range(10):\n29:         p = update_probability(p, True)\n30:     assert p > 0.9, f\"xác suất phải tiệm cận cao khi đúng liên tục, got {p}\"\n31: \n32: \n33: def test_wrong_decreases():\n34:     p = PRIOR\n35:     for _ in range(10):\n36:         p = update_probability(p, False)\n37:     # xác suất phải giảm rõ rệt so với prior (transit giữ nó không xuống sát 0)\n38:     assert p < 0.4, f\"xác suất phải giảm khi sai liên tục, got {p}\"\n39: \n40: \n41: def test_root_cause_tracing():\n42:     # Học sinh làm sai as3.u8.l3 (There was/were) do yếu gốc as3.u3.l3 (To Be)\n43:     mastery = compute_mastery(_mk_answers(\"as3.u8.l3\", 0, 3))\n44:     # To Be (as3.u3.l3) là tiên quyết, giả định cũng yếu (default prior)\n45:     gaps = diagnose_gaps(mastery)\n46:     gap_ids = {g[\"skill_id\"] for g in gaps}\n47:     assert \"as3.u8.l3\" in gap_ids\n48:     # truy ngược phải chỉ ra as3.u3.l3 là gốc (vì prior < ROOT_THRESHOLD)\n49:     assert \"as3.u3.l3\" in gap_ids\n50: \n51: \n52: def test_no_gap_when_mastered():\n53:     mastery = compute_mastery(_mk_answers(\"as3.u1.l3\", 10, 0))\n54:     gaps = diagnose_gaps(mastery)\n55:     assert all(g[\"skill_id\"] != \"as3.u1.l3\" for g in gaps)\n56: \n57: \n58: def test_unknown_skill_fallback():\n59:     mastery = compute_mastery(_mk_answers(\"xxx.unknown\", 0, 1))\n60:     gaps = diagnose_gaps(mastery)\n61:     assert any(g[\"skill_id\"] == \"xxx.unknown\" and g[\"status\"] == \"unknown\" for g in gaps)\n62: \n63: \n64: def test_trace_root_causes_empty_when_ok():\n65:     mastery = {\"as3.u8.l3\": {\"probability\": 0.9}}\n66:     assert trace_root_causes(\"as3.u8.l3\", mastery) == []\n67: \n68: \n69: if __name__ == \"__main__\":\n70:     test_correct_increases()\n71:     test_wrong_decreases()\n72:     test_root_cause_tracing()\n73:     test_no_gap_when_mastered()\n74:     test_unknown_skill_fallback()\n75:     test_trace_root_causes_empty_when_ok()\n76:     print(\"All BKT tests passed.\")\n77: \nThe above content shows the entire, complete file contents of the requested file.\n"}
