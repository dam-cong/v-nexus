{"step_index":26,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T09:27:04Z","content":"Created At: 2026-07-18T16:27:04+07:00\nCompleted At: 2026-07-18T16:27:04+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/agent/planner.py`\nTotal Lines: 55\nTotal Bytes: 2206\nShowing lines 1 to 55\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"Planner Agent — MỘT agent duy nhất của hệ thống.\n2: \n3: Nhận tin nhắn, gọi LLM, thực thi tool qua Tool Registry khi model yêu cầu, lặp tới khi\n4: có câu trả lời cuối. Không thêm agent thứ hai ở đây — logic domain-specific (prompt +\n5: tool nào được dùng) nằm trong DomainAdapter (xem domain/adapter.py).\n6: \"\"\"\n7: from agent.llm_client import create_message\n8: from domain.adapter import DomainAdapter\n9: from tools.registry import ToolRegistry\n10: \n11: \n12: class PlannerAgent:\n13:     def __init__(self, domain: DomainAdapter, model: str = \"claude-sonnet-5\") -> None:\n14:         self.domain = domain\n15:         self.model = model\n16:         self.registry = ToolRegistry()\n17:         for tool in domain.tools():\n18:             self.registry.register(tool)\n19: \n20:     async def run(self, message: str, history: list[dict]) -> tuple[str, list[dict]]:\n21:         messages = [*history, {\"role\": \"user\", \"content\": message}]\n22:         tool_specs = self.registry.specs()\n23: \n24:         response = create_message(\n25:             model=self.model,\n26:             system=self.domain.system_prompt(),\n27:             messages=messages,\n28:             tools=tool_specs,\n29:         )\n30: \n31:         while response.stop_reason == \"tool_use\":\n32:             messages.append({\"role\": \"assistant\", \"content\": response.content})\n33:             tool_results = []\n34:             for block in response.content:\n35:                 if block.type == \"tool_use\":\n36:                     result = await self.registry.call(block.name, block.input)\n37:                     tool_results.append(\n38:                         {\n39:                             \"type\": \"tool_result\",\n40:                             \"tool_use_id\": block.id,\n41:                             \"content\": str(result),\n42:                         }\n43:                     )\n44:             messages.append({\"role\": \"user\", \"content\": tool_results})\n45:             response = create_message(\n46:                 model=self.model,\n47:                 system=self.domain.system_prompt(),\n48:                 messages=messages,\n49:                 tools=tool_specs,\n50:             )\n51: \n52:         reply = \"\".join(block.text for block in response.content if block.type == \"text\")\n53:         messages.append({\"role\": \"assistant\", \"content\": reply})\n54:         return reply, messages\n55: \nThe above content shows the entire, complete file contents of the requested file.\n"}
