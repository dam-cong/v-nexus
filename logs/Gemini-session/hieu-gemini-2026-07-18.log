{"step_index":36,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T06:43:45Z","content":"Created At: 2026-07-18T13:43:45+07:00\nCompleted At: 2026-07-18T13:43:45+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/agent/planner.py`\nTotal Lines: 67\nTotal Bytes: 2826\nShowing lines 1 to 67\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"Planner Agent — MỘT agent duy nhất của hệ thống.\n2: \n3: Nhận tin nhắn, gọi LLM, thực thi tool qua Tool Registry khi model yêu cầu, lặp tới khi\n4: có câu trả lời cuối. Không thêm agent thứ hai ở đây — logic domain-specific (prompt +\n5: tool nào được dùng) nằm trong DomainAdapter (xem domain/adapter.py).\n6: \"\"\"\n7: from agent.llm_client import create_message, call_llm\n8: from app.config import settings\n9: from domain.adapter import DomainAdapter\n10: from tools.registry import ToolRegistry\n11: \n12: \n13: class PlannerAgent:\n14:     def __init__(self, domain: DomainAdapter, model: str = \"claude-sonnet-5\") -> None:\n15:         self.domain = domain\n16:         self.model = model\n17:         self.registry = ToolRegistry()\n18:         for tool in domain.tools():\n19:             self.registry.register(tool)\n20: \n21:     async def run(self, message: str, history: list[dict]) -> tuple[str, list[dict]]:\n22:         # --- Offline mode: dùng template fallback, không gọi LLM ---\n23:         if settings.llm_mode == \"offline\":\n24:             reply = (\n25:                 \"Em đang ở chế độ offline. \"\n26:                 \"Hệ thống BKT vẫn hoạt động bình thường — \"\n27:                 \"hãy trả lời câu hỏi để em được đánh giá kỹ năng nhé!\"\n28:             )\n29:             messages = [*history, {\"role\": \"user\", \"content\": message}, {\"role\": \"assistant\", \"content\": reply}]\n30:             return reply, messages\n31: \n32:         # --- Online mode: gọi LLM (Anthropic) ---\n33:         messages = [*history, {\"role\": \"user\", \"content\": message}]\n34:         tool_specs = self.registry.specs()\n35: \n36:         response = create_message(\n37:             model=self.model,\n38:             system=self.domain.system_prompt(),\n39:             messages=messages,\n40:             tools=tool_specs,\n41:         )\n42: \n43:         while response.stop_reason == \"tool_use\":\n44:             messages.append({\"role\": \"assistant\", \"content\": response.content})\n45:             tool_results = []\n46:             for block in response.content:\n47:                 if block.type == \"tool_use\":\n48:                     result = await self.registry.call(block.name, block.input)\n49:                     tool_results.append(\n50:                         {\n51:                             \"type\": \"tool_result\",\n52:                             \"tool_use_id\": block.id,\n53:                             \"content\": str(result),\n54:                         }\n55:                     )\n56:             messages.append({\"role\": \"user\", \"content\": tool_results})\n57:             response = create_message(\n58:                 model=self.model,\n59:                 system=self.domain.system_prompt(),\n60:                 messages=messages,\n61:                 tools=tool_specs,\n62:             )\n63: \n64:         reply = \"\".join(block.text for block in response.content if block.type == \"text\")\n65:         messages.append({\"role\": \"assistant\", \"content\": reply})\n66:         return reply, messages\n67: \nThe above content shows the entire, complete file contents of the requested file.\n"}
