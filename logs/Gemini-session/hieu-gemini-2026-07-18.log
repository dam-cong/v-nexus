{"step_index":8,"source":"MODEL","type":"VIEW_FILE","status":"DONE","created_at":"2026-07-18T09:26:35Z","content":"Created At: 2026-07-18T16:26:35+07:00\nCompleted At: 2026-07-18T16:26:35+07:00\nFile Path: `file:///home/hieu/Downloads/Code/VAIC%202026/v-nexus/agent/llm_client.py`\nTotal Lines: 72\nTotal Bytes: 2368\nShowing lines 1 to 72\nThe following code has been modified to include a line number before every line, in the format: <line_number>: <original_line>. Please note that any changes targeting the original code should remove the line number, colon, and leading space.\n1: \"\"\"LLM client: hỗ trợ cả Anthropic (cũ) và FPT AI Inference (OpenAI-compatible).\n2: \n3: FPT endpoint là OpenAI-compatible: https://mkp-api.fptcloud.com/v1\n4: Model mặc định: DeepSeek-V4-Flash (cấu hình qua env FPT_MODEL).\n5: \"\"\"\n6: import os\n7: \n8: from app.config import settings\n9: \n10: \n11: def create_message(*, model: str, system: str, messages: list[dict], tools: list[dict]):\n12:     \"\"\"Giữ nguyên API cho Anthropic (dùng bởi /chat cũ).\"\"\"\n13:     from anthropic import Anthropic\n14: \n15:     _client = Anthropic(api_key=os.environ.get(\"ANTHROPIC_API_KEY\", \"\"))\n16:     return _client.messages.create(\n17:         model=model,\n18:         system=system,\n19:         messages=messages,\n20:         tools=tools,\n21:         max_tokens=1024,\n22:     )\n23: \n24: \n25: def create_message_fpt(*, system: str, messages: list[dict], tools: list[dict] = None, model: str = None):\n26:     \"\"\"Gọi FPT AI Inference (OpenAI-compatible chat completions).\n27: \n28:     Trả về dict: {\"text\": str, \"tool_calls\": [{\"name\", \"input\"}]} để Planner Agent\n29:     (hoặc tool trực tiếp) dễ sử dụng. Nếu không có tool_call thì chỉ có text.\n30:     \"\"\"\n31:     from openai import OpenAI\n32: \n33:     client = OpenAI(base_url=settings.fpt_api_base, api_key=settings.fpt_api_key, timeout=30.0)\n34:     req_model = model or settings.fpt_model\n35: \n36:     openai_tools = None\n37:     if tools:\n38:         openai_tools = [\n39:             {\n40:                 \"type\": \"function\",\n41:                 \"function\": {\n42:                     \"name\": t[\"name\"],\n43:                     \"description\": t.get(\"description\", \"\"),\n44:                     \"parameters\": t.get(\"input_schema\", t.get(\"parameters\", {})),\n45:                 },\n46:             }\n47:             for t in tools\n48:         ]\n49: \n50:     completion = client.chat.completions.create(\n51:         model=req_model,\n52:         messages=[{\"role\": \"system\", \"content\": system}, *messages],\n53:         tools=openai_tools,\n54:         tool_choice=\"auto\" if openai_tools else None,\n55:         temperature=0.3,\n56:     )\n57:     choice = completion.choices[0].message\n58: \n59:     text = choice.content or \"\"\n60:     tool_calls = []\n61:     if getattr(choice, \"tool_calls\", None):\n62:         for tc in choice.tool_calls:\n63:             import json\n64: \n65:             try:\n66:                 args = json.loads(tc.function.arguments or \"{}\")\n67:             except Exception:\n68:                 args = {}\n69:             tool_calls.append({\"name\": tc.function.name, \"input\": args})\n70: \n71:     return {\"text\": text, \"tool_calls\": tool_calls}\n72: \nThe above content shows the entire, complete file contents of the requested file.\n"}
