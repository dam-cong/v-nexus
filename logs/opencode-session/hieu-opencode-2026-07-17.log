timestamp=2026-07-17T14:00:20.457Z level=INFO run=cde86b95 message=evaluated permission=bash pattern="python3 -c \"\nimport json\n\nwith open('docs/data/knowledge-graph.json', encoding='utf-8') as f:\n    raw = json.load(f)\n\n# Build prerequisite map from edges\nprereq_map = {}\nfor edge in raw.get('edges', []):\n    target = edge.get('to', '')\n    source = edge.get('from', '')\n    if target not in prereq_map:\n        prereq_map[target] = []\n    prereq_map[target].append(source)\n\nskills = []\nfor node in raw['nodes']:\n    prereqs = prereq_map.get(node['skill_id'], [])\n\n    skill_type = 'vocabulary'\n    lt = node.get('lesson_title', '').lower()\n    if 'grammar' in lt:\n        skill_type = 'grammar'\n    elif 'reading' in lt or 'write' in lt:\n        skill_type = 'reading'\n    elif 'listening' in lt or 'speak' in lt:\n        skill_type = 'listening'\n\n    skills.append({\n        'id': node['skill_id'],\n        'code_gdpt': node['skill_id'],\n        'name_vi': node.get('lesson_title', node['skill_id']),\n        'name_en': node.get('lesson_title', node['skill_id']),\n        'grade': node.get('grade', 3),\n        'unit': node.get('unit_name', ''),\n        'skill_type': skill_type,\n        'p_init': 0.3,\n        'p_transit': 0.3,\n        'p_slip': 0.1,\n        'p_guess': 0.2,\n        'prerequisites': prereqs,\n    })\n\nkg_output = {\n    'subject': 'Tiếng Anh',\n    'grades': [3, 4],\n    'curriculum': 'Academy Stars 3 & 4',\n    'skills': skills,\n}\n\nwith open('ai/knowledge_graph.json', 'w', encoding='utf-8') as f:\n    json.dump(kg_output, f, ensure_ascii=False, indent=2)\nprint(f'Done: {len(skills)} skills, {sum(len(s[\\\"prerequisites\\\"]) for s in skills)} edges')\n\n# Verify some skills have prerequisites\nhas_prereq = sum(1 for s in skills if s['prerequisites'])\nprint(f'Skills with prerequisites: {has_prereq}')\n\"" action.permission=* action.action=allow action.pattern=*
