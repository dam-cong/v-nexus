timestamp=2026-07-17T13:59:33.492Z level=INFO run=cde86b95 message=evaluated permission=bash pattern="python3 -c \"\nimport json\n\n# 1. Convert knowledge-graph.json\nwith open('docs/data/knowledge-graph.json', encoding='utf-8') as f:\n    raw = json.load(f)\n\nskills = []\nfor node in raw['nodes']:\n    # Map prerequisites from edges (linear chain)\n    prereqs = []\n    for edge in raw.get('edges', []):\n        if edge.get('target') == node['skill_id']:\n            prereqs.append(edge['source'])\n\n    skill_type = 'vocabulary'\n    lesson_title = node.get('lesson_title', '').lower()\n    if 'grammar' in lesson_title:\n        skill_type = 'grammar'\n    elif 'reading' in lesson_title or 'write' in lesson_title:\n        skill_type = 'reading'\n    elif 'listening' in lesson_title or 'speak' in lesson_title:\n        skill_type = 'listening'\n\n    skills.append({\n        'id': node['skill_id'],\n        'code_gdpt': node.get('skill_id', ''),\n        'name_vi': node.get('lesson_title', node.get('skill_id', '')),\n        'name_en': node.get('lesson_title', node.get('skill_id', '')),\n        'grade': node.get('grade', 3),\n        'unit': node.get('unit_name', ''),\n        'skill_type': skill_type,\n        'p_init': 0.3,\n        'p_transit': 0.3,\n        'p_slip': 0.1,\n        'p_guess': 0.2,\n        'prerequisites': prereqs,\n    })\n\nkg_output = {\n    'subject': 'Tiếng Anh',\n    'grades': [3, 4],\n    'curriculum': 'Academy Stars 3 & 4',\n    'skills': skills,\n}\n\nwith open('ai/knowledge_graph.json', 'w', encoding='utf-8') as f:\n    json.dump(kg_output, f, ensure_ascii=False, indent=2)\nprint(f'knowledge_graph.json: {len(skills)} skills')\n\n# 2. Convert question-bank.json\nwith open('docs/data/question-bank.json', encoding='utf-8') as f:\n    raw_q = json.load(f)\n\ndiff_map = {'easy': 1, 'medium': 2, 'hard': 3}\nquestions = []\nfor q in raw_q['questions']:\n    options = tuple(opt['label'] for opt in q.get('options', []))\n    correct_idx = 0\n    for i, opt in enumerate(q.get('options', [])):\n        if opt['option_id'] == q.get('correct_option_id'):\n            correct_idx = i\n            break\n\n    questions.append({\n        'id': q['question_id'],\n        'skill_id': q['skill_id'],\n        'content': q.get('prompt', {}).get('text', ''),\n        'options': list(options),\n        'correct_answer': correct_idx,\n        'difficulty': diff_map.get(q.get('difficulty', 'medium'), 2),\n        'source': 'question-bank',\n    })\n\nqb_output = {'questions': questions}\n\nwith open('tools/questions.json', 'w', encoding='utf-8') as f:\n    json.dump(qb_output, f, ensure_ascii=False, indent=2)\nprint(f'questions.json: {len(questions)} questions')\n\"" action.permission=* action.action=allow action.pattern=*
