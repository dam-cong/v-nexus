timestamp=2026-07-17T14:07:14.536Z level=INFO run=cde86b95 message=evaluated permission=bash pattern="python3 -c \"\nimport os, re\n\n# Mapping of old skill IDs to new ones\nREPLACE_MAP = {\n    'M6.RA.FRAC01': 'as3.welcome.l1',\n    'M6.RA.FRAC02': 'as3.welcome.l2',\n    'M6.RA.FRAC03': 'as3.u1.l1',\n    'M6.RA.FRAC04': 'as3.u1.l2',\n    'M6.RA.FRAC05': 'as3.u1.l3',\n    'M6.RA.DEC01': 'as3.u1.l4',\n}\n\n# Also fix text assertions\nTEXT_REPLACEMENTS = {\n    '\\\"Phân số và phân số đơn vị\\\"': '\\\"Welcome\\\"',\n}\n\ntest_files = [\n    'tests/test_bkt_engine.py',\n    'tests/test_tools.py',\n    'tests/test_domain_adapter.py',\n    'tests/test_integration.py',\n    'tests/test_adaptive_test.py',\n]\n\nfor filepath in test_files:\n    with open(filepath, 'r') as f:\n        content = f.read()\n    \n    for old_id, new_id in REPLACE_MAP.items():\n        content = content.replace(old_id, new_id)\n    \n    with open(filepath, 'w') as f:\n        f.write(content)\n    \n    # Count remaining M6.RA refs\n    remaining = len(re.findall(r'M6\\\\.RA\\\\.', content))\n    print(f'{filepath}: {remaining} remaining M6.RA refs')\n\nprint('Done')\n\"" action.permission=* action.action=allow action.pattern=*
