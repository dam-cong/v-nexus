timestamp=2026-07-18T03:40:07.792Z level=INFO run=8e60842d message=evaluated permission=bash pattern="python -c \"\nimport sys, os\nsys.path.insert(0, os.path.abspath('.'))\nfrom domain.bkt import generate_learning_steps, format_steps_for_llm\n\n# Edge case 1: empty gaps\nsteps = generate_learning_steps({}, [])\nassert steps == [], f'Expected empty, got {steps}'\nprint('Edge case 1 (empty gaps): OK')\n\n# Edge case 2: mixed severity\ngaps = [\n    {'skill_id': 'as3.u3.l3', 'skill_name': 'To Be', 'probability': 0.1, 'severity': 'high', 'root_causes': [], 'reason': 'root cause'},\n    {'skill_id': 'as3.u1.l3', 'skill_name': 'Present Simple', 'probability': 0.35, 'severity': 'medium', 'root_causes': ['as3.u3.l3'], 'reason': 'needs prereq'},\n]\nmastery = {'as3.u3.l3': {'probability': 0.1, 'status': 'weak'}, 'as3.u1.l3': {'probability': 0.35, 'status': 'weak'}}\nsteps = generate_learning_steps(mastery, gaps)\nassert len(steps) == 2, f'Expected 2 steps, got {len(steps)}'\nassert steps[0]['severity'] == 'high', f'Expected high first, got {steps[0][\\\"severity\\\"]}'\nassert steps[1]['severity'] == 'medium', f'Expected medium second, got {steps[1][\\\"severity\\\"]}'\nassert steps[0]['suggested_difficulty'] == 'easy', f'Expected easy for high, got {steps[0][\\\"suggested_difficulty\\\"]}'\nassert steps[1]['suggested_difficulty'] == 'medium', f'Expected medium for medium, got {steps[1][\\\"suggested_difficulty\\\"]}'\nprint('Edge case 2 (mixed severity ordering): OK')\n\n# Edge case 3: format_steps_for_llm\ntable = format_steps_for_llm(steps)\nassert 'To Be' in table\nassert 'KHÔNG được sửa đổi' in table\nprint('Edge case 3 (format table): OK')\n\n# Edge case 4: empty steps formatting\nempty_table = format_steps_for_llm([])\nassert 'nắm vững tất cả' in empty_table\nprint('Edge case 4 (empty table): OK')\n\nprint()\nprint('ALL EDGE CASES PASSED')\n\"" action.permission=* action.action=allow action.pattern=*
